---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="CONCES ATBU R&D - Contact">
  <!-- Header Section -->
  <section class="py-20 px-4 sm:px-6 lg:px-8 bg-gradient-to-b from-background to-secondary/30 border-b border-surface/40 relative overflow-hidden">
    <div class="absolute top-0 right-1/4 w-96 h-96 bg-primary/5 blur-[100px] rounded-full pointer-events-none"></div>
    <div class="max-w-7xl mx-auto relative z-10">
      <h1 class="text-4xl md:text-5xl font-extrabold text-text mb-4 tracking-tight">
        Get In Touch
      </h1>
      <p class="text-base md:text-lg text-subtle max-w-2xl font-normal">
        Interested in partnership or collaboration? We'd love to hear from you.
      </p>
    </div>
  </section>

  <!-- Contact Form Section -->
  <section class="py-16 px-4 sm:px-6 lg:px-8 bg-background relative z-10">
    <div class="max-w-2xl mx-auto">
      <form id="contact-form" class="space-y-6">
        <div>
          <label for="org-name" class="block text-xs font-semibold uppercase tracking-wider text-muted mb-2">
            Organization Name *
          </label>
          <input
            type="text"
            id="org-name"
            name="organizationName"
            required
            class="w-full px-4 py-3 rounded-xl bg-secondary border border-surface/80 text-text placeholder-subtle/50 focus:outline-none focus:border-primary/60 focus:ring-1 focus:ring-primary/40 transition-all font-sans"
            placeholder="Your organization name"
          />
        </div>

        <div>
          <label for="project-focus" class="block text-xs font-semibold uppercase tracking-wider text-muted mb-2">
            Project Focus *
          </label>
          <input
            type="text"
            id="project-focus"
            name="projectFocus"
            required
            class="w-full px-4 py-3 rounded-xl bg-secondary border border-surface/80 text-text placeholder-subtle/50 focus:outline-none focus:border-primary/60 focus:ring-1 focus:ring-primary/40 transition-all font-sans"
            placeholder="Describe your project focus area"
          />
        </div>

        <div>
          <label for="email" class="block text-xs font-semibold uppercase tracking-wider text-muted mb-2">
            Email Address *
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full px-4 py-3 rounded-xl bg-secondary border border-surface/80 text-text placeholder-subtle/50 focus:outline-none focus:border-primary/60 focus:ring-1 focus:ring-primary/40 transition-all font-sans"
            placeholder="your@email.com"
          />
        </div>

        <div>
          <label for="message" class="block text-xs font-semibold uppercase tracking-wider text-muted mb-2">
            Message Details *
          </label>
          <textarea
            id="message"
            name="message"
            required
            rows="5"
            class="w-full px-4 py-3 rounded-xl bg-secondary border border-surface/80 text-text placeholder-subtle/50 focus:outline-none focus:border-primary/60 focus:ring-1 focus:ring-primary/40 transition-all font-sans resize-none"
            placeholder="Tell us about your partnership or collaboration proposal"
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full bg-primary text-background font-semibold px-8 py-3.5 rounded-xl hover:bg-primary/90 transition-all duration-300 shadow-lg shadow-primary/5 hover:shadow-primary/10 cursor-pointer"
        >
          Send Message
        </button>
      </form>

      <!-- Message Alert Dialog Box Banner Container -->
      <div id="form-message" class="mt-6 p-4 rounded-xl text-sm font-medium transition-all duration-300 hidden"></div>
    </div>
  </section>

  <!-- Official Channels Direct Links Section (z-30 ensures click pass-through) -->
  <section class="py-20 px-4 sm:px-6 lg:px-8 bg-secondary/20 border-t border-surface/40 relative z-30">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold text-text mb-12 text-center tracking-tight">
        Official Connect Channels
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        
        <!-- Official Email Link -->
        <a 
          href="mailto:atbu.conces@gmail.com" 
          class="bg-secondary/40 border border-surface/60 rounded-2xl p-6 text-center hover:border-primary/50 hover:bg-secondary/60 hover:-translate-y-1 transition-all duration-300 block cursor-pointer group pointer-events-auto"
        >
          <div class="text-primary w-8 h-8 mx-auto mb-4 group-hover:scale-110 transition-transform">
            <svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
          </div>
          <h3 class="text-sm font-bold text-text uppercase tracking-wider mb-2">Email</h3>
          <!-- Swapped text-subtle to text-primary with dynamic group hover effects -->
          <p class="text-xs font-mono text-primary font-medium group-hover:underline truncate">
            atbu.conces@gmail.com
          </p>
        </a>


        <!-- Official LinkedIn Link -->
        <a 
          href="https://www.linkedin.com/in/conces-atbu-075060410/" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="bg-secondary/40 border border-surface/60 rounded-2xl p-6 text-center hover:border-primary/50 hover:bg-secondary/60 hover:-translate-y-1 transition-all duration-300 block cursor-pointer group pointer-events-auto"
        >
          <div class="text-primary w-8 h-8 mx-auto mb-4 group-hover:scale-110 transition-transform">
            <svg fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
          </div>
          <h3 class="text-sm font-bold text-text uppercase tracking-wider mb-2">LinkedIn</h3>
          <p class="text-xs text-primary font-medium group-hover:underline">Follow Profile</p>
        </a>

        <!-- Official Facebook Link -->
        <a 
          href="https://www.facebook.com/p/Conces-Atbu-Chapter-61559696067560/" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="bg-secondary/40 border border-surface/60 rounded-2xl p-6 text-center hover:border-primary/50 hover:bg-secondary/60 hover:-translate-y-1 transition-all duration-300 block cursor-pointer group pointer-events-auto"
        >
          <div class="text-primary w-8 h-8 mx-auto mb-4 group-hover:scale-110 transition-transform">
            <svg fill="currentColor" viewBox="0 0 24 24"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/></svg>
          </div>
          <h3 class="text-sm font-bold text-text uppercase tracking-wider mb-2">Facebook</h3>
          <p class="text-xs text-primary font-medium group-hover:underline">Connect Page</p>
        </a>

        <!-- Official WhatsApp Link -->
        <a 
          href="https://wa.me/2347047568443" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="bg-secondary/40 border border-surface/60 rounded-2xl p-6 text-center hover:border-primary/50 hover:bg-secondary/60 hover:-translate-y-1 transition-all duration-300 block cursor-pointer group pointer-events-auto"
        >
          <div class="text-primary w-8 h-8 mx-auto mb-4 group-hover:scale-110 transition-transform">
            <svg fill="currentColor" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397 0 11.93 0c3.165.001 6.14 1.233 8.377 3.474 2.237 2.241 3.469 5.214 3.468 8.379-.003 6.582-5.338 11.93-11.87 11.93-2.007-.001-3.98-.51-5.725-1.486L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.747 1.451 5.436 0 9.86-4.42 9.863-9.855.001-2.632-1.022-5.105-2.885-6.969-1.864-1.864-4.333-2.887-6.964-2.888-5.439 0-9.865 4.425-9.867 9.861-.001 1.748.496 3.454 1.442 4.965l-.993 3.63 3.713-.974zm11.236-4.58c-.287-.143-1.696-.837-1.959-.933-.262-.096-.452-.143-.642.143-.19.285-.737.933-.903 1.122-.165.189-.332.214-.618.071-.285-.143-1.207-.444-2.299-1.419-.85-.758-1.424-1.693-1.59-1.979-.166-.285-.018-.439.125-.581.128-.127.285-.332.428-.499.142-.166.19-.285.285-.475.095-.19.047-.356-.024-.499-.071-.142-.642-1.545-.88-2.114-.231-.557-.466-.481-.642-.49-.17-.008-.364-.01-.559-.01-.195 0-.514.073-.783.369-.27.295-1.026 1.002-1.026 2.443 0 1.44 1.049 2.833 1.196 3.03.147.197 2.064 3.15 5.001 4.417.699.301 1.244.482 1.669.617.702.223 1.341.192 1.846.117.563-.083 1.696-.693 1.934-1.362.239-.669.239-1.241.167-1.362-.072-.121-.262-.193-.549-.336z"/></svg>
          </div>
          <h3 class="text-sm font-bold text-text uppercase tracking-wider mb-2">WhatsApp</h3>
          <p class="text-xs text-primary font-medium group-hover:underline">Message Chat</p>
        </a>

      </div>
    </div>
  </section>
</MainLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const formMessage = document.getElementById('form-message');

  if (form && formMessage) {
    form.addEventListener('submit', function (e) {
      e.preventDefault();

      const formData = new FormData(form);
      const data = Object.fromEntries(formData);
      console.log('Contact form data logged:', data);

      // Render modern high-fidelity verification dialog banner block
      formMessage.textContent = 'Thank you for your message! We will get back to you soon.';
      formMessage.className = 'mt-6 p-4 rounded-xl text-center bg-emerald-500/10 text-emerald-400 border border-emerald-500/30 text-sm font-medium block';
      formMessage.classList.remove('hidden');

      // Clear input fields smoothly
      form.reset();

      // Terminate alert visibility thread accurately after a 5 second delay loop
      setTimeout(() => {
        formMessage.classList.add('hidden');
      }, 5000);
    });
  }
</script>
