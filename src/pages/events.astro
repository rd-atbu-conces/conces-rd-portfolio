---
import MainLayout from '../layouts/MainLayout.astro';

const allEventsRaw = await Astro.glob('../content/events/*.json');


// 2. Sort them chronologically so index [0] is ALWAYS the newest flagship event
const sortedEvents = allEventsRaw.sort((a, b) => {
  return new Date(b.date).getTime() - new Date(a.date).getTime();
});

// 3. Isolate the newest event and push the rest into the history logs matrix
const latestEvent = sortedEvents[0];
const pastEvents = sortedEvents.slice(1);

// Helper function to format the ISO dates cleanly for academic readability
const formatDate = (dateString: string) => {
  return new Date(dateString).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
};
---

<MainLayout title="CONCES ATBU R&D - Events Timeline">
  <!-- Master Timeline Page Layout Wrapper -->
  <div class="bg-background min-h-screen py-16 px-4 sm:px-6 lg:px-8">
    <div class="max-w-6xl mx-auto">
      
      <!-- Section Branding Header -->
      <header class="mb-16">
        <span class="text-xs font-mono uppercase tracking-widest text-primary bg-primary/5 border border-primary/10 px-3 py-1 rounded-md">
          Timeline Chronicles
        </span>
        <h1 class="text-4xl md:text-5xl font-extrabold text-text tracking-tight mt-4 mb-2">
          Exhibitions & Symposia
        </h1>
        <p class="text-base md:text-lg text-subtle max-w-2xl font-normal">
          Chronological logs mapping our institutional evaluation phases, collaborative hackathons, and annual science exhibitions.
        </p>
      </header>

      {latestEvent ? (
        <!-- FLAGSHIP ZONE: CENTER OF ATTENTION -->
        <div class="space-y-12">
          <section class="relative bg-secondary/30 border border-surface/80 rounded-2xl p-6 md:p-10 hover:border-primary/30 transition-all duration-300 overflow-hidden shadow-xl">
            <!-- Neon background design matrix glow -->
            <div class="absolute top-0 right-0 w-80 h-80 bg-gradient-to-bl from-primary/10 via-transparent to-transparent opacity-60 pointer-events-none rounded-bl-full"></div>
            
            <div class="relative z-10 grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">
              
              <!-- Left Column: Title & Context Details -->
              <div class="lg:col-span-2 space-y-4">
                <div class="flex items-center gap-3">
                  <span class="bg-primary text-background text-[10px] font-mono font-black uppercase tracking-wider px-2.5 py-0.5 rounded-md animate-pulse">
                    LATEST EVENT LOG
                  </span>
                  <span class="text-xs font-mono text-primary font-semibold">
                    {formatDate(latestEvent.date)}
                  </span>
                </div>
                
                <h2 class="text-2xl md:text-4xl font-bold text-text tracking-tight leading-tight">
                  {latestEvent.title}
                </h2>
                
                <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-xs font-mono text-subtle">
                  <span class="flex items-center gap-1">
                    📍 {latestEvent.location}
                  </span>
                </div>

                <p class="text-subtle text-sm md:text-base leading-relaxed pt-2 font-normal max-w-3xl">
                  {latestEvent.description}
                </p>

                <!-- Link Pipeline to take user back to the filtered list -->
                <div class="pt-4">
                  <a 
                    href="/conces-rd-portfolio/archive" 
                    class="inline-flex items-center gap-2 bg-primary text-background font-semibold text-xs uppercase tracking-wider px-5 py-2.5 rounded-xl hover:bg-primary/90 transition-all duration-200"
                  >
                    View Exhibition Submissions
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                    </svg>
                  </a>
                </div>
              </div>

              <!-- Right Column: Analytical Metric Cards Block -->
              <div class="bg-background/40 border border-surface/60 rounded-xl p-6 space-y-4 font-mono">
                <h3 class="text-xs font-bold uppercase tracking-wider text-muted border-b border-surface/50 pb-2">
                  Exhibition Summary Metrics
                </h3>
                
                <div class="flex justify-between items-center py-1">
                  <span class="text-xs text-subtle uppercase">Cataloged Ingest</span>
                  <span class="text-sm font-bold text-text">{latestEvent.metrics?.submissions || 0} Modules</span>
                </div>

                <div class="flex justify-between items-center py-1">
                  <span class="text-xs text-subtle uppercase">Selected Finalists</span>
                  <span class="text-sm font-bold text-accent">{latestEvent.metrics?.finalists || 0} Projects</span>
                </div>

                <div class="flex justify-between items-center py-1">
                  <span class="text-xs text-subtle uppercase">Jury Panel Matrix</span>
                  <span class="text-sm font-bold text-primary">{latestEvent.metrics?.panelists || 0} Reviewers</span>
                </div>
              </div>

            </div>
          </section>

          <!-- HISTORY ZONE: THE GRIDS FOR PAST EVENTS -->
          {pastEvents.length > 0 && (
            <section class="pt-8 space-y-6">
              <h2 class="text-xl font-bold text-text tracking-tight uppercase font-mono text-xs text-subtle border-b border-surface/40 pb-3">
                Historical Exhibition Archives Log
              </h2>
              
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                {pastEvents.map((event) => (
                  <div class="bg-secondary/20 border border-surface/40 rounded-xl p-6 flex flex-col justify-between hover:border-surface/80 transition-colors duration-200 relative group">
                    <div class="space-y-3">
                      <span class="text-xs font-mono text-subtle/80 block">
                        {formatDate(event.date)}
                      </span>
                      <h3 class="text-lg font-bold text-text tracking-tight group-hover:text-primary transition-colors">
                        {event.title}
                      </h3>
                      <p class="text-subtle text-xs leading-relaxed line-clamp-3">
                        {event.description}
                      </p>
                    </div>

                    <div class="pt-4 flex items-center justify-between border-t border-surface/20 mt-4 text-xs font-mono text-subtle">
                      <span>📍 {event.location.split(',')[0]}</span>
                      <span class="text-primary group-hover:underline">Explore Log →</span>
                    </div>
                  </div>
                ))}
              </div>
            </section>
          )}
        </div>
      ) : (
        <!-- Fallback empty view parameter state -->
        <div class="text-center py-16 border border-dashed border-surface rounded-2xl max-w-md mx-auto">
          <p class="text-sm font-mono text-subtle">No event timelines recorded inside this repository module yet.</p>
        </div>
      )}

    </div>
  </div>
</MainLayout>
