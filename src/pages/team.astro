---
import MainLayout from '../layouts/MainLayout.astro';
import teamData from '../content/team/members.json';

const leadership = teamData.filter(m => m.type === 'Leadership');
const fellows = teamData.filter(m => m.type === 'R&D Fellow');
const contributors = teamData.filter(m => m.type === 'Contributor');
---

<MainLayout title="CONCES ATBU R&D - Team">
  <!-- Header Section -->
  <section class="py-20 px-4 sm:px-6 lg:px-8 bg-gradient-to-b from-background to-secondary/30 border-b border-surface/40 relative overflow-hidden">
    <div class="absolute top-0 right-1/4 w-96 h-96 bg-primary/5 blur-[100px] rounded-full pointer-events-none"></div>
    <div class="max-w-7xl mx-auto relative z-10">
      <h1 class="text-4xl md:text-5xl font-extrabold text-text mb-4 tracking-tight">
        Our Team
      </h1>
      <p class="text-base md:text-lg text-subtle max-w-2xl font-normal">
        Meet the brilliant minds driving innovation, engineering, and digital discovery at CONCES ATBU.
      </p>
    </div>
  </section>

  <!-- Filter Section -->
  <section class="py-6 px-4 sm:px-6 lg:px-8 bg-secondary/20 sticky top-20 z-30 backdrop-blur-md border-b border-surface/50">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-wrap gap-2.5">
        <button
          class="team-filter active text-xs font-semibold uppercase tracking-wider px-5 py-2.5 rounded-xl border border-primary/20 bg-primary text-background transition-all duration-200"
          data-team="all"
        >
          All Members
        </button>
        <button
          class="team-filter text-xs font-semibold uppercase tracking-wider px-5 py-2.5 rounded-xl border border-surface text-subtle hover:text-text hover:border-muted bg-background/50 transition-all duration-200"
          data-team="Leadership"
        >
          Leadership
        </button>
        <button
          class="team-filter text-xs font-semibold uppercase tracking-wider px-5 py-2.5 rounded-xl border border-surface text-subtle hover:text-text hover:border-muted bg-background/50 transition-all duration-200"
          data-team="R&D Fellow"
        >
          R&D Fellows
        </button>
        <button
          class="team-filter text-xs font-semibold uppercase tracking-wider px-5 py-2.5 rounded-xl border border-surface text-subtle hover:text-text hover:border-muted bg-background/50 transition-all duration-200"
          data-team="Contributor"
        >
          Contributors
        </button>
      </div>
    </div>
  </section>

  <!-- Leadership Section -->
  <section class="py-16 px-4 sm:px-6 lg:px-8 bg-background team-section transition-all duration-300 transform scale-100 opacity-100" data-team="Leadership">
    <div class="max-w-7xl mx-auto">
      <h2 class="text-2xl font-bold text-text mb-8 tracking-tight border-l-4 border-primary pl-4">Leadership</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {leadership.map(member => (
          <div class="bg-secondary/40 backdrop-blur-sm border border-surface/80 rounded-2xl p-6 hover:border-primary/40 hover:shadow-xl hover:shadow-primary/5 transition-all duration-300 text-center group">
            {/* Avatar Container with Image Fallback Support */}
            <div class="w-20 h-20 rounded-full bg-primary/10 text-primary border border-primary/20 flex items-center justify-center font-bold text-xl mb-4 mx-auto font-display group-hover:scale-105 transition-transform duration-300 overflow-hidden relative">
              {member.avatar ? (
                <img 
                  src={member.avatar} 
                  alt={member.name} 
                  class="w-full h-full object-cover absolute inset-0 opacity-0 transition-opacity duration-300"
                  onload="this.classList.remove('opacity-0')"
                />
              ) : null}
              <span class="relative z-0">{member.initials}</span>
            </div>
            <h3 class="text-lg font-bold text-text mb-1 tracking-tight group-hover:text-primary transition-colors">
              {member.name}
            </h3>
            <p class="text-sm font-medium text-subtle mb-3">{member.role}</p>
            <span class="inline-block text-[10px] font-mono tracking-widest uppercase bg-surface/60 text-muted px-2.5 py-1 rounded-md border border-surface">
              Batch {member.batchYear}
            </span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- R&D Fellows Section -->
  <section class="py-16 px-4 sm:px-6 lg:px-8 bg-background team-section transition-all duration-300 transform scale-100 opacity-100" data-team="R&D Fellow">
    <div class="max-w-7xl mx-auto">
      <h2 class="text-2xl font-bold text-text mb-8 tracking-tight border-l-4 border-accent pl-4">R&D Fellows</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {fellows.map(member => (
          <div class="bg-secondary/40 backdrop-blur-sm border border-surface/80 rounded-2xl p-6 hover:border-accent/40 hover:shadow-xl hover:shadow-accent/5 transition-all duration-300 text-center group">
            <div class="w-20 h-20 rounded-full bg-accent/10 text-accent border border-accent/20 flex items-center justify-center font-bold text-xl mb-4 mx-auto font-display group-hover:scale-105 transition-transform duration-300 overflow-hidden relative">
              {member.avatar ? (
                <img 
                  src={member.avatar} 
                  alt={member.name} 
                  class="w-full h-full object-cover absolute inset-0 opacity-0 transition-opacity duration-300"
                  onload="this.classList.remove('opacity-0')"
                />
              ) : null}
              <span class="relative z-0">{member.initials}</span>
            </div>
            <h3 class="text-lg font-bold text-text mb-1 tracking-tight group-hover:text-accent transition-colors">
              {member.name}
            </h3>
            <p class="text-sm font-medium text-subtle mb-3">{member.role}</p>
            <span class="inline-block text-[10px] font-mono tracking-widest uppercase bg-surface/60 text-muted px-2.5 py-1 rounded-md border border-surface">
              Batch {member.batchYear}
            </span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contributors Section -->
  <section class="py-16 px-4 sm:px-6 lg:px-8 bg-background team-section transition-all duration-300 transform scale-100 opacity-100" data-team="Contributor">
    <div class="max-w-7xl mx-auto">
      <h2 class="text-2xl font-bold text-text mb-8 tracking-tight border-l-4 border-emerald-500 pl-4">Contributors</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {contributors.map(member => (
          <div class="bg-secondary/40 backdrop-blur-sm border border-surface/80 rounded-2xl p-6 hover:border-emerald-500/40 hover:shadow-xl hover:shadow-emerald-500/5 transition-all duration-300 text-center group">
            <div class="w-20 h-20 rounded-full bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 flex items-center justify-center font-bold text-xl mb-4 mx-auto font-display group-hover:scale-105 transition-transform duration-300 overflow-hidden relative">
              {member.avatar ? (
                <img 
                  src={member.avatar} 
                  alt={member.name} 
                  class="w-full h-full object-cover absolute inset-0 opacity-0 transition-opacity duration-300"
                  onload="this.classList.remove('opacity-0')"
                />
              ) : null}
              <span class="relative z-0">{member.initials}</span>
            </div>
            <h3 class="text-lg font-bold text-text mb-1 tracking-tight group-hover:text-emerald-400 transition-colors">
              {member.name}
            </h3>
            <p class="text-sm font-medium text-subtle mb-3">{member.role}</p>
            <span class="inline-block text-[10px] font-mono tracking-widest uppercase bg-surface/60 text-muted px-2.5 py-1 rounded-md border border-surface">
              Batch {member.batchYear}
            </span>
          </div>
        ))}
      </div>
    </div>
  </section>
</MainLayout>

<script>
  const filterButtons = document.querySelectorAll('.team-filter');
  const teamSections = document.querySelectorAll<HTMLElement>('.team-section');

  filterButtons.forEach(button => {
    button.addEventListener('click', () => {
      const team = button.getAttribute('data-team');

      filterButtons.forEach(btn => {
        btn.classList.remove('active', 'bg-primary', 'text-background', 'border-primary/20');
        btn.classList.add('text-subtle', 'border-surface', 'bg-background/50');
      });
      button.classList.add('active', 'bg-primary', 'text-background', 'border-primary/20');
      button.classList.remove('text-subtle', 'border-surface', 'bg-background/50');

      teamSections.forEach(section => {
        const sectionTeam = section.getAttribute('data-team');
        if (team === 'all' || sectionTeam === team) {
          section.classList.remove('hidden', 'opacity-0', 'scale-95');
          section.classList.add('block', 'opacity-100', 'scale-100');
        } else {
          section.classList.remove('block', 'opacity-100', 'scale-100');
          section.classList.add('hidden', 'opacity-0', 'scale-95');
        }
      });
    });
  });
</script>
