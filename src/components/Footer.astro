      <!-- Info Column -->
      <div class="text-center md:text-left space-y-2">
        <h3 class="text-text font-bold text-xl tracking-tight font-display">
          CONCES <span class="text-primary">ATBU</span>
        </h3>
        <p class="text-subtle text-xs leading-relaxed max-w-sm mx-auto md:mx-0">
          Center for Research and Development in Engineering and Sciences
        </p>
      </div>

      <!-- Quick Links Column -->
      <div class="flex flex-wrap justify-center gap-x-8 gap-y-3 text-sm font-medium">
